fun GetWindowPosY() -> f32 = native;
fun GetWindowSizeX() -> f32 = native;
fun GetWindowSizeY() -> f32 = native;
fun GetWindowWidth() -> f32 = native;
fun GetWindowHeight() -> f32 = native;
