fun EndChild() -> unit = native;
fun SetNextWindowSize(width: f32, height: f32, cond: i32) -> unit = native;
fun SetNextWindowPos(x: f32, y: f32, cond: i32) -> unit = native;
fun SetNextWindowCollapsed(collapsed: bool, cond: i32) -> unit = native;
fun SetNextWindowFocus() -> unit = native;
