fun TreePop() -> unit = native;
fun BeginTabBar(id: string) -> bool = native;
fun EndTabBar() -> unit = native;
fun BeginTabItem(label: string) -> bool = native;
fun EndTabItem() -> unit = native;
fun BeginMenuBar() -> bool = native;
fun EndMenuBar() -> unit = native;
