fun SetKeyboardFocusHere(offset: i32) -> unit = native;
fun SetNextItemAllowOverlap() -> unit = native;
fun BeginDisabled(disabled: bool) -> unit = native;
fun EndDisabled() -> unit = native;
fun BeginTooltip() -> bool = native;
fun EndTooltip() -> unit = native;
fun SetTooltip(text: string) -> unit = native;
fun SetItemTooltip(text: string) -> unit = native;
fun PushStyleColor(idx: i32, r: f32, g: f32, b: f32, a: f32) -> unit = native;
fun PopStyleColor(count: i32) -> unit = native;
fun PushStyleVarFloat(idx: i32, value: f32) -> unit = native;
fun PushStyleVarVec2(idx: i32, x: f32, y: f32) -> unit = native;
fun PopStyleVar(count: i32) -> unit = native;

// Text and widgets.
fun Text(str: string) -> unit = native;
fun TextDisabled(str: string) -> unit = native;
fun TextWrapped(str: string) -> unit = native;
fun LabelText(label: string, text: string) -> unit = native;
fun BulletText(str: string) -> unit = native;
fun TextColored(r: f32, g: f32, b: f32, a: f32, text: string) -> unit = native;
fun TextNgHighlighted(source: string) -> unit = native;
fun Bullet() -> unit = native;
fun Button(label: string) -> bool = native;
fun ButtonSized(label: string, width: f32, height: f32) -> bool = native;
fun SmallButton(label: string) -> bool = native;
fun Checkbox(label: string, checked: bool) -> bool = native;
fun RadioButton(label: string, active: bool) -> bool = native;
fun SliderFloat(label: string, value: f32, min: f32, max: f32) -> f32 = native;
fun SliderInt(label: string, value: i32, min: i32, max: i32) -> i32 = native;
fun DragFloat(label: string, value: f32, speed: f32, min: f32, max: f32) -> f32 = native;
fun DragInt(label: string, value: i32, speed: f32, min: i32, max: i32) -> i32 = native;
fun InputText(label: string, value: string, flags: i32) -> string = native;
fun InputTextMultiline(label: string, value: string, width: f32, height: f32, flags: i32) -> string = native;
fun InputFloat(label: string, value: f32, step: f32, stepFast: f32, flags: i32) -> f32 = native;
fun InputInt(label: string, value: i32, step: i32, stepFast: i32, flags: i32) -> i32 = native;
fun Selectable(label: string, selected: bool, flags: i32, width: f32, height: f32) -> bool = native;
fun BeginCombo(label: string, preview: string, flags: i32) -> bool = native;
fun EndCombo() -> unit = native;
fun ProgressBar(fraction: f32, width: f32, height: f32, overlay: string) -> unit = native;

// Tables.
fun BeginTable(id: string, columns: i32, flags: i32, outerWidth: f32, outerHeight: f32, innerWidth: f32) -> bool = native;
fun EndTable() -> unit = native;
