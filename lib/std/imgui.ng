fun MenuItem(label: string, selected: bool) -> bool = native;
fun OpenPopup(id: string) -> unit = native;
fun BeginPopup(id: string) -> bool = native;
fun EndPopup() -> unit = native;

// Runtime queries.
fun IsItemHovered() -> bool = native;
fun IsItemClicked(button: i32) -> bool = native;
fun IsItemActive() -> bool = native;
fun IsItemFocused() -> bool = native;
