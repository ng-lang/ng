module std.imgui exports *;

type ImGuiContext = native;
type ImGuiIO = native;
type ImGuiStyle = native;

// SDL/GPU lifecycle managed by the std.imgui wrapper.
fun init() -> unit = native;
fun eventLoop() -> unit = native;
fun checkMinimized() -> unit = native;
fun NewFrame() -> unit = native;
fun Render() -> unit = native;
fun Aborted() -> bool = native;
fun cleanup() -> unit = native;

// Context, IO, and style handles.
fun GetVersion() -> string = native;
fun GetCurrentContext() -> ImGuiContext = native;
fun SetCurrentContext(ctx: ImGuiContext) -> unit = native;
fun GetIO() -> ImGuiIO = native;
fun GetStyle() -> ImGuiStyle = native;

fun ImGuiIO_GetConfigFlags(io: ImGuiIO) -> i32 = native;
fun ImGuiIO_SetConfigFlags(io: ImGuiIO, flags: i32) -> unit = native;
fun ImGuiIO_AddConfigFlags(io: ImGuiIO, flags: i32) -> unit = native;
fun ImGuiIO_ClearConfigFlags(io: ImGuiIO, flags: i32) -> unit = native;
fun ImGuiIO_GetFramerate(io: ImGuiIO) -> f32 = native;
fun ImGuiIO_GetDeltaTime(io: ImGuiIO) -> f32 = native;
fun ImGuiIO_GetWantCaptureMouse(io: ImGuiIO) -> bool = native;
fun ImGuiIO_GetWantCaptureKeyboard(io: ImGuiIO) -> bool = native;
fun ImGuiIO_GetFontGlobalScale(io: ImGuiIO) -> f32 = native;
fun ImGuiIO_SetFontGlobalScale(io: ImGuiIO, scale: f32) -> unit = native;

fun StyleColorsDark() -> unit = native;
fun StyleColorsLight() -> unit = native;
fun StyleColorsClassic() -> unit = native;
fun ImGuiStyle_ScaleAllSizes(style: ImGuiStyle, scale: f32) -> unit = native;
fun ImGuiStyle_GetAlpha(style: ImGuiStyle) -> f32 = native;
fun ImGuiStyle_SetAlpha(style: ImGuiStyle, alpha: f32) -> unit = native;
fun ImGuiStyle_GetWindowRounding(style: ImGuiStyle) -> f32 = native;
fun ImGuiStyle_SetWindowRounding(style: ImGuiStyle, rounding: f32) -> unit = native;
fun ImGuiStyle_GetFrameRounding(style: ImGuiStyle) -> f32 = native;
fun ImGuiStyle_SetFrameRounding(style: ImGuiStyle, rounding: f32) -> unit = native;

