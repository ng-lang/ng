type Counter {
    label: string;
}

trait Show {
    fun show(self: ref<Self>) -> string;
}

impl Show for Counter {
    fun show(self: ref<Self>) -> string {
        return self.label;
    }
}

fun render<T: Show>(value: ref<T>) -> string {
    return value.show();
}

val counter = new Counter { label: "eleven" };
print(render(counter));
