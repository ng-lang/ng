// Union Type Annotations
// =======================
// NG supports union types using the `|` syntax.
// A union type allows a value to be one of several types.

// Simple union type: i32 or string
val x: i32 | string = 1
val y: i32 | string = "hello"

// Multiple union members
val z: bool | i32 | f32 = true
val w: bool | i32 | f32 = 42

// Union types in function parameters
fun describe(value: i32 | string) -> unit
  = print("got a value")

// Union types in return types
fun safe_parse(input: string) -> i32 | string
  = if input == "ok" then 1 else "error"

// Type checking ensures only matching types are assigned
val parsed: i32 | string = safe_parse("test")

describe(x)
describe(y)
</path>
