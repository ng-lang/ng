type Person {
    firstName: string;
    lastName: string;
    kid;

    fun name() -> string {
        return self.firstName + " " + self.lastName;
    }
}

val person = new Person {
    firstName: "Kimmy",
    lastName: "Leo",
    kid: new Person {
        firstName: "Tiny",
        lastName: "Leo",
        kid: unit
    }
};

print(person.name());
print(person.kid.name());
